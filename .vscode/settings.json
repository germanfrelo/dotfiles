{
	// Formatting
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"[markdown]": {
		"editor.renderWhitespace": "boundary"
	},
	"editor.formatOnSave": true,

	// Spell checking
	"cSpell.ignoreWords": [],
	"cSpell.words": [
		"chezmoi",
		"chezmoiignore",
		"chezmoiroot",
		"chezmoiscripts",
		"create-pull-request",
		"darwin",
		"github",
		"linux",
		"onepassword",
		"onepasswordRead",
		"peter-evans",
		"tmpl"
	],

	// File associations
	"files.associations": {
		".chezmoi.toml.tmpl": "toml",
		".nvmrc": "properties",
		"*.sh.tmpl": "shellscript",
		"*dot_zshenv": "shellscript",
		"*ignore": "ignore",
		"dot_zprofile": "shellscript",
		"dot_zshrc": "shellscript",
		"LICENSE": "plaintext",
		"npmrc": "properties",
		"pre-commit": "shellscript",
		"private_config.tmpl": "properties"
	},

	// Workspace color customizations
	"workbench.colorCustomizations": {
		"statusBar.background": "#4051b5",
		"statusBar.foreground": "#d9ddf2",
		"statusBarItem.hoverBackground": "#33408F",
		"statusBarItem.hoverForeground": "#fff"
	}
}
