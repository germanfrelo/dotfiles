{
	// Formatting
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"[markdown]": {
		"editor.renderWhitespace": "boundary"
	},
	"editor.formatOnSave": true,

	// Spell checking
	"cSpell.ignoreWords": [],
	"cSpell.words": [
		"chezmoi",
		"chezmoiignore",
		"chezmoiroot",
		"chezmoiscripts",
		"create-pull-request",
		"darwin",
		"github",
		"linux",
		"onepassword",
		"onepasswordRead",
		"peter-evans",
		"tmpl"
	],

	// File associations
	"files.associations": {
		// editorconfig
		"*dot_editorconfig": "editorconfig",

		// ignore
		"*ignore": "ignore",

		// ini
		"**/*git/*config*": "ini",

		// plaintext
		"LICENSE": "plaintext",

		// properties
		"**/*ncdu/*config*": "properties",

		// shellscript
		"*.sh.tmpl": "shellscript",
		"*dot_zprofile": "shellscript",
		"*dot_zshenv": "shellscript",
		"*dot_zshrc": "shellscript",
		"pre-commit": "shellscript",

		// toml
		"*.toml.tmpl": "toml"
	},

	// Workspace color customizations
	"workbench.colorCustomizations": {
		"statusBar.background": "#4051b5",
		"statusBar.foreground": "#d9ddf2",
		"statusBarItem.hoverBackground": "#33408F",
		"statusBarItem.hoverForeground": "#fff"
	}
}
