{
	"name": "dotfiles",
	"version": "0.1.0",
	"private": true,
	"description": "My dotfiles, managed with chezmoi.",
	"keywords": [
		"dotfiles",
		"macos",
		"chezmoi"
	],
	"homepage": "https://github.com/germanfrelo/dotfiles",
	"bugs": {
		"url": "https://github.com/germanfrelo/dotfiles/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/germanfrelo/dotfiles.git"
	},
	"license": "MIT",
	"author": "Germán Freixinós",
	"type": "module",
	"main": "",
	"scripts": {
		"chezmoi:sync": "node scripts/sync-chezmoi-config.js",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"managed": "node scripts/managed.js > MANAGED.txt",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.*": [
			"prettier --write --ignore-unknown"
		]
	},
	"devDependencies": {
		"husky": "9.1.7",
		"lint-staged": "17.0.5",
		"markdownlint-cli2": "0.22.1",
		"prettier": "3.8.4"
	}
}
