# TODO: Consider adding these impactful, low-maintenance options, structured by the capability they provide:
# - **Automatically set up upstream branches on first push.** `[push] autoSetupRemote = true` prevents the tedious `git push --set-upstream origin <branch>` error when you create a new local branch. Git will just do it for you automatically. *(Requires Git 2.37+).*
# - **Keep your local branch list clutter-free.** `[fetch] prune = true` automatically deletes local tracking references when their counterparts are deleted on the remote (e.g., after a pull request is merged).
# - **Generate much more readable and logical diffs.** `[diff] algorithm = histogram` replaces the default diff engine with one that is significantly better at understanding moved code blocks and curly braces, resulting in human-friendly diffs.
# - **Find your active branches faster.** `[branch] sort = -committerdate` sorts the output of your `git branch` command by the most recent commits first, keeping your active work at the top rather than hiding it in an alphabetical list.
# - **See the original base code during merge conflicts.** `[merge] conflictStyle = zdiff3` changes how conflict markers are written in the raw file. Instead of just showing "ours" and "theirs", it also shows the original code both sides diverged from, providing crucial context. *(Requires Git 2.35+).*
# - **Keep your commit history linear and clean.** `[pull] rebase = true` forces Git to rebase your local unpushed commits on top of the incoming changes, preventing those messy, automated "Merge branch 'main' into main" commits.

[user]
	name = Germán Freixinós
	email = 14282156+germanfrelo@users.noreply.github.com

[init]
	defaultBranch = main

[help]
	autocorrect = prompt

# Display the number of entries currently stashed away.
[status]
	showStash = true

# Automatically use .git-blame-ignore-revs in any repo that has one.
# Ref. https://stackoverflow.com/a/79824780
[blame]
	ignoreRevsFile = :(optional).git-blame-ignore-revs

# Handle line endings properly.
# Ref. https://docs.github.com/en/get-started/git-basics/configuring-git-to-handle-line-endings
[core]
{{- if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") }}
	autocrlf = input # macOS & Linux
{{- else if eq .chezmoi.os "windows" }}
	autocrlf = true # Windows
{{- else }}
	autocrlf = input
{{- end }}

# Use VS Code as Git editor, diff tool and merge tool.
# Ref. https://code.visualstudio.com/docs/sourcecontrol/overview#_vs-code-as-git-editor
[core]
	editor = code --wait
[diff]
	tool = vscode
[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE
[merge]
	tool = vscode
[mergetool "vscode"]
	cmd = code --wait --merge $REMOTE $LOCAL $BASE $MERGED

# Commit signing with SSH and 1Password.
# Ref. https://developer.1password.com/docs/ssh/git-commit-signing/
[user]
	signingkey = {{ onepasswordRead "op://jzkvauzqt3adjmfkfl6ros3gc4/rzvcj7ec56xzr2ys5otprcvdsq/public_key" "VAEUN74C7FFWJITFMLLEXLAYFA" }}
[commit]
	gpgsign = true
[gpg]
	format = ssh
{{- if eq .chezmoi.os "darwin" }}
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
{{- end }}
