# ALIASES

# --- Extending Pre-existing Aliases (Dynamic Syntax) ---

# The zsh4humans framework automatically creates hidden aliases for the commands 'diff, 'grep' and 'ls' to ensure they use the correct colour flags for the OS. See https://github.com/romkatv/zsh4humans/blob/v5/fn/-z4h-init
# The dynamic syntax ${aliases[cmd]:-cmd} syntax must be used here. This safely appends my custom flags to the end of the framework's aliases without destroying the colour settings.

# If these need to be overridden in the future, uncomment and replace "..." with the desired flags.
# alias diff="${aliases[diff]:-diff} ..."
# alias grep="${aliases[grep]:-grep} ..."
# alias ls="${aliases[ls]:-ls} ..."

# ------------------------------

# Reload the current shell cleanly to apply configuration changes.
alias reload="exec zsh"

# --- Navigation & Shortcuts ---

# --- DIRS: Display the directory stack (recently visited directories) ---

# Display a numbered list of entries in the directory stack with one entry per line.
alias dirs="dirs -v"

# Quick access to the directory stack by index.
for index in {1..9}; do alias "${index}"="cd +${index}"; done
unset index

# --- Directories Shortcuts ---

# Shortcuts to frequently used directories.
alias repos="${HOME}/repos/germanfrelo"

# --- Files & Directories Listing ---

# EZA: Lists the contents of the current directory

# Override default behaviour with better options.
alias eza="eza -F -A --oneline --group-directories-first"

# Display files/dirs as a detailed metadata table.
alias ezal="eza --long --header --smart-group --blocksize --total-size --flags --time-style=relative --no-user --git --git-repos"


# List Directory Contents in a Tree-like Format

# Visualise directory structures recursively
alias tree="tree -aFC --dirsfirst -I .git"

# Visualise directory structures up to a specific depth
alias tree1="tree -L 1"
alias tree2="tree -L 2"
alias tree3="tree -L 3"

# --- File Contents ---

# View file contents with syntax highlighting (bypassing the pager)
alias bat="bat --paging=never"

# --- Searching ---

# Find patterns in files using regular expressions
alias grep="grep -i"

# --- Actions on Files and Directories ---

# Actions on files and directories
alias cp="cp -iv"
alias mv="mv -iv"
alias rm="rm -iv"

# --- Network & External Tools ---

# Download files preserving HSTS states in the XDG cache
alias wget='wget --hsts-file="${XDG_CACHE_HOME}/wget-hsts"'

