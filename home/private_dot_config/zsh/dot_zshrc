# Define functions and completions.

# Create a new directory and instantly navigate into it (with folder tab-completion)
function md() { [[ $# == 1 ]] && mkdir -p -- "$1" && cd -- "$1"; }
compdef _directories md

# Append the HEAD commit hash to .git-blame-ignore-revs.
# Only runs if the commit title matches style*:* (case-insensitive).
# Skips automatically if the commit is itself a .git-blame-ignore-revs update.
function gbignore() {
	local commit_hash commit_title title_lower

	commit_hash="$(git rev-parse HEAD 2>/dev/null)" || {
		print -P "%F{red}Error: not a git repository or no commits.%f" >&2
		return 1
	}
	commit_title="$(git log -1 --format=%s)"
	title_lower="${commit_title:l}"

	case "${title_lower}" in
		*git-blame-ignore-revs*)
			print -P "%F{yellow}Skipped: commit appears to be a .git-blame-ignore-revs update.%f" >&2
			return 1
			;;
	esac

	case "${title_lower}" in
		style*:*) ;;
		*)
			print -P "%F{red}Aborted: \"%s\" does not match style*:*.%f" "${commit_title}" >&2
			return 1
			;;
	esac

	if [[ ! -f .git-blame-ignore-revs ]]; then
		print -P "%F{red}Error: .git-blame-ignore-revs not found in %~.%f" >&2
		return 1
	fi

	if grep -qF "${commit_hash}" .git-blame-ignore-revs; then
		print -P "%F{yellow}Skipped: %s is already in .git-blame-ignore-revs.%f" "${commit_hash}" >&2
		return 0
	fi

	printf "\n# %s\n%s\n" "${commit_title}" "${commit_hash}" >> .git-blame-ignore-revs
	git add .git-blame-ignore-revs
	git commit -m "chore: Update .git-blame-ignore-revs"
	print -P "%F{green}Done: added %s to .git-blame-ignore-revs.%f" "${commit_hash}"
}

# Copies a file to all subdirectories in the current path, excluding the source directory.
# Usage: syncfile path/to/source/.gitattributes
syncfile() {
	local src_file="$1"

	# 1. Validation: Ensure source file exists
	if [[ ! -f "${src_file}" ]]; then
		echo "🚫 Error: Source file '${src_file}' not found."
		return 1
	fi

	# 2. Extraction: Get the filename and the absolute path of its parent directory
	local filename="$(basename "${src_file}")"
	local src_dir_abs="$(cd "$(dirname "${src_file}")" && pwd)"

	echo "🚀 Syncing '${filename}' to all repositories (excluding origin)..."

	# 3. Execution: Loop through all directories
	for dir in */; do
		# Remove trailing slash for path comparison
		local target_dir="${dir%/}"
		local target_dir_abs="$(cd "${target_dir}" && pwd)" || continue

		# Skip the directory that contains the source file
		if [[ "${target_dir_abs}" == "${src_dir_abs}" ]]; then
			echo "🏠 Skipping source: ${target_dir}"
			continue
		fi

		# Only sync to directories that are actually Git repositories (optional, but safer for you)
		if [[ -d "${target_dir}/.git" ]]; then
			cp "${src_file}" "${target_dir}/${filename}"
			echo "✅ Synced to: ${target_dir}"
		fi
	done
}

